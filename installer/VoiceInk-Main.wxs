<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="VoiceInk" Language="1033" Version="1.2.0.0"
           Manufacturer="VoiceInk" UpgradeCode="E8A8E8D4-1234-4321-ABCD-EF1234567890">

    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of VoiceInk is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="mszip" />

    <Property Id="ARPURLINFOABOUT" Value="https://github.com/zyjhandsome/VoiceInk" />

    <Icon Id="VoiceInkIcon" SourceFile="..\voiceink\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="VoiceInkIcon" />

    <Feature Id="ProductFeature" Title="VoiceInk" Level="1">
      <ComponentGroupRef Id="VoiceInkFiles" />
    </Feature>

    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <CustomAction Id="LaunchApp" Directory="INSTALLFOLDER" ExeCommand="VoiceInk.exe" Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApp" After="InstallFinalize">NOT Installed AND NOT REMOVE</Custom>
    </InstallExecuteSequence>

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="VoiceInk" />
      </Directory>
      <Directory Id="DesktopFolder" />
      <Directory Id="ProgramMenuFolder" />
    </Directory>
  </Fragment>

</Wix>